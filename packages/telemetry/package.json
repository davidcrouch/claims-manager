{
  "name": "@morezero/telemetry",
  "version": "0.1.0",
  "description": "OpenTelemetry integration for MoreZero applications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component",
    "clean": "rimraf -I --glob .turbo .vercel dist tsconfig.tsbuildinfo **/*.d.ts **/*.d.ts.map **/*.js.map",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.65.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.206.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.206.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-metrics": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.206.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "@opentelemetry/sdk-trace-web": "^2.1.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/context-zone": "^2.1.0",
    "@opentelemetry/instrumentation": "^0.206.0",
    "@opentelemetry/instrumentation-document-load": "^0.51.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.51.0",
    "@opentelemetry/instrumentation-fetch": "^0.206.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "default": "./dist/web/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "default": "./dist/shared/index.js"
    }
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0"
  }
}
