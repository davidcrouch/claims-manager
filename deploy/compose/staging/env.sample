# deploy/compose/staging/env.sample
#
# Documents every environment variable consumed by the staging compose stack.
# Real values are rendered into /var/lib/claims-manager/staging.env at boot
# by modules/staging_vm/startup.sh, using Secret Manager.
#
# DO NOT commit real secrets here. This file is only a schema.

# ── Image tag (set by CI for each deploy) ─────────────────────────────
IMAGE_TAG=

# ── Application environment ──────────────────────────────────────────
APP_ENV=staging
NODE_ENV=production
LOG_LEVEL=info

# ── Public hostnames (Caddy routes, OIDC redirect builders) ──────────
API_HOST=api.staging.branlamie.com
AUTH_HOST=auth.staging.branlamie.com
APP_HOST=app.staging.branlamie.com
CADDY_ADMIN_EMAIL=ops@branlamie.com

# ── Postgres (CloudSQL, private IP via VPC peering) ──────────────────
DATABASE_URL_API=postgres://claims_manager_admin:<pw>@<cloudsql-private-ip>:5432/claims_manager?sslmode=disable
DATABASE_URL_AUTH=postgres://claims_manager_admin:<pw>@<cloudsql-private-ip>:5432/auth?sslmode=disable

# ── Redis (Memorystore, private IP) ──────────────────────────────────
# REDIS_URL is the canonical secret; startup.sh parses REDIS_HOST/REDIS_PORT out of it.
REDIS_URL=redis://<memorystore-host>:6379
REDIS_HOST=<memorystore-host>
REDIS_PORT=6379

# ── API server ────────────────────────────────────────────────────────
CREDENTIALS_ENCRYPTION_KEY=

# ── Auth-server JWT / OIDC keys ──────────────────────────────────────
AUTH_JWT_SECRET=
JWT_PUBLIC_KEY_N=
JWT_PRIVATE_KEY_D=
JWT_PRIVATE_KEY_P=
JWT_PRIVATE_KEY_Q=
JWT_PRIVATE_KEY_DP=
JWT_PRIVATE_KEY_DQ=
JWT_PRIVATE_KEY_QI=
JWT_EC_PRIVATE_KEY_D=
JWT_EC_PUBLIC_KEY_X=
JWT_EC_PUBLIC_KEY_Y=
DYNAMIC_REGISTRATION_SECRET=
DCR_IAT_SIGNING_KEY=
OIDC_COOKIES_KEYS=

# ── Auth-server: static OIDC client shared with frontend ─────────────
AUTH_OIDC_CLIENT_SECRET=

# ── Google OAuth (auth-server social login) ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Frontend ─────────────────────────────────────────────────────────
FRONTEND_OIDC_COOKIE_SECRET=

# ── GCS (signed URLs / object storage) ───────────────────────────────
GCS_HMAC_ACCESS_KEY=
GCS_HMAC_SECRET_KEY=
