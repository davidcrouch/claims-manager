# More0AI Shared Infrastructure Environment Configuration
# Copy this file to .env and adjust values as needed
# Port values from .env.ports (block 3200-3299). See .cursor/rules/port-allocation.mdc.
#
# Apps use DATABASE_URL for DB connection. Compose builds it from the vars below.
# See docs/ENV_NAMING.md for the common env naming scheme.
#
# cp env.example .env

# Database (used by infra pgsql and to build DATABASE_URL for app services)
# Standardize on more0ai — registry, admin-ui, chat, workers all use this.
DB_DATABASE=more0ai
DB_USERNAME=more0ai
DB_PASSWORD=secret
DB_PORT=3210

# Redis
PORT_REDIS=3250

# MinIO (Object Storage)
MINIO_ROOT_USER=sail
MINIO_ROOT_PASSWORD=password
PORT_MINIO=3230
PORT_MINIO_CONSOLE=3231

# Mailpit (Email)
PORT_SMTP=3240
PORT_MAIL_UI=3241

# Observability
PORT_OTEL_GRPC=3270
PORT_OTEL_HTTP=3271
PORT_OTEL_METRICS=3272
PORT_TEMPO=3273
PORT_LOKI=3274
PORT_PROMETHEUS=3275
PORT_GRAFANA=3276
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Billing Service
PORT_BILLING=3282
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_CONNECT_CLIENT_ID=ca_your_client_id_here
