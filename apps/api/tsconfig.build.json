{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Pin rootDir to src/ so tsc mirrors the src tree into dist/ instead of
    // inferring rootDir from the longest common path of all inputs. Without
    // this, any .ts sitting beside src/ (e.g. drizzle.config.ts) shifts the
    // common path up to apps/api/, which produces dist/src/**/*.js (and
    // breaks `node dist/main.js` and `node dist/database/run-migrations.js`
    // in the production image).
    "rootDir": "./src",
    // Keep the incremental build cache inside dist/ so it is cleared whenever
    // nest-cli deletes the output directory (`deleteOutDir: true`). Otherwise
    // a stale cache at the repo root makes tsc believe outputs already exist
    // and it emits nothing after dist/ has been wiped, leaving
    // `node dist/main.js` unable to resolve the entrypoint.
    "tsBuildInfoFile": "./dist/tsconfig.build.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts"]
}
