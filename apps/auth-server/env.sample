# =============================================================================
# ENSUREOS AUTH SERVER - ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains all environment variables required for the EnsureOS Auth Server.
# The Auth Server provides OAuth2.1/OIDC authentication services for the EnsureOS product.
# 

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Basic server configuration
NODE_ENV=production                     # Environment: development, production, test
PORT=4000                              # Port number for the auth server to listen on

# Service identification (optional - defaults to 'auth-server')
SERVICE_NAME=auth-server                # Service name for telemetry and logging
SERVICE_VERSION=0.2.1                  # Service version (optional - uses package.json by default)
OTEL_SERVICE_NAME=auth-server          # OpenTelemetry service name (standard)

# OIDC Issuer URL - The base URL for this OAuth2.1/OIDC provider
# This is used in discovery endpoints and token validation
OIDC_ISSUER=https://auth.example.com

# =============================================================================
# SECURITY CONFIGURATION (REQUIRED)
# =============================================================================
# JWT Secret - Used for signing and verifying JWT tokens
# Must be at least 32 characters long, use a cryptographically secure random string
JWT_SECRET=d3c6255ece6129f44b123d7d7eac73ada6ff2a3c6a9c17b7c67d1469070b4673bba010dced7291ce8eb39eed0e72f364559b77f5cff02f7e7e5cac803f296627

