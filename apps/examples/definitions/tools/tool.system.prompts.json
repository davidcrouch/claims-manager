{
  "name": "tool.system.prompts",
  "display_name": "System Prompts",
  "type": "tool",
  "version": "1.0.0",
  "description": "Manage prompt definitions in the capability registry. A prompt provides the system instruction (persona, rules, constraints) given to an LLM. Prompts are referenced by agents via their name.",
  "tags": [
    "system",
    "management",
    "prompts"
  ],
  "methods": {
    "info": {
      "description": "Tool capability metadata",
      "channels": [
        "sync"
      ]
    },
    "create": {
      "description": "Create a new prompt definition. A prompt provides the system instruction given to an LLM — it defines the persona, rules, and constraints the model follows. Prompts are referenced by agents. For example, to create a prompt named 'prompt.support.triage', provide app='my-app', name='prompt.support.triage', prompt_text='You are a support triage agent...'.",
      "input": {
        "type": "object",
        "properties": {
          "app": {
            "type": "string",
            "description": "App key that owns this prompt. Example: 'my-app'"
          },
          "name": {
            "type": "string",
            "description": "Prompt name. Example: 'prompt.support.triage'"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of what this prompt does. Example: 'System prompt for the support ticket triage agent'"
          },
          "prompt_text": {
            "type": "string",
            "description": "The system prompt content. Supports markdown. This is the instruction text the LLM receives. Example: 'You are a support triage agent. Classify incoming tickets by priority...'"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional tags for discovery. Example: ['support', 'triage']"
          },
          "version": {
            "type": "object",
            "properties": {
              "major": {
                "type": "number"
              },
              "minor": {
                "type": "number"
              },
              "patch": {
                "type": "number"
              }
            },
            "description": "Optional version. Defaults to 1.0.0 if omitted."
          }
        },
        "required": [
          "app",
          "name",
          "description",
          "prompt_text"
        ]
      },
      "output": {
        "type": "object",
        "properties": {
          "cap": {
            "type": "string",
            "description": "Full capability reference (app/name)"
          },
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "description": "'created' or 'updated'"
          },
          "error": {
            "type": "string",
            "description": "Error message if the operation failed"
          }
        }
      },
      "semantics": "work",
      "channels": [
        "sync"
      ]
    },
    "get": {
      "description": "Get full details of a prompt by name. Returns the prompt metadata and version info.",
      "input": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Full prompt name or capability reference. Example: 'prompt.support.triage' or 'my-app/prompt.support.triage'"
          }
        },
        "required": [
          "name"
        ]
      },
      "output": {
        "type": "object",
        "properties": {
          "cap": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "methods": {
            "type": "array"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "semantics": "informational",
      "channels": [
        "sync"
      ]
    },
    "list": {
      "description": "List prompt definitions. Optionally filter by app or tags.",
      "input": {
        "type": "object",
        "properties": {
          "app": {
            "type": "string",
            "description": "Filter by app key. Example: 'my-app'"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Filter by tags. Example: ['support']"
          },
          "query": {
            "type": "string",
            "description": "Free-text search query"
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "prompts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "cap": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "version": {
                  "type": "string"
                }
              }
            }
          },
          "total": {
            "type": "number"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "semantics": "informational",
      "channels": [
        "sync"
      ]
    },
    "update": {
      "description": "Update an existing prompt definition. Provide only the fields you want to change. The version patch number is auto-incremented.",
      "input": {
        "type": "object",
        "properties": {
          "app": {
            "type": "string",
            "description": "App key that owns this prompt. Example: 'my-app'"
          },
          "name": {
            "type": "string",
            "description": "Name of the prompt to update. Example: 'prompt.support.triage'"
          },
          "description": {
            "type": "string",
            "description": "Updated description (optional)"
          },
          "prompt_text": {
            "type": "string",
            "description": "Updated prompt text (optional)"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Updated tags (optional)"
          }
        },
        "required": [
          "app",
          "name"
        ]
      },
      "output": {
        "type": "object",
        "properties": {
          "cap": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "semantics": "work",
      "channels": [
        "sync"
      ]
    },
    "delete": {
      "description": "Deprecate a prompt definition. It remains in the registry but is marked as deprecated and no longer discoverable by default.",
      "input": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Full prompt name or capability reference. Example: 'my-app/prompt.support.triage'"
          },
          "reason": {
            "type": "string",
            "description": "Reason for deprecation. Example: 'Replaced by prompt.support.triage-v2'"
          }
        },
        "required": [
          "name",
          "reason"
        ]
      },
      "output": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "affected_versions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "error": {
            "type": "string"
          }
        }
      },
      "semantics": "work",
      "channels": [
        "sync"
      ]
    }
  },
  "implementation": {
    "kind": "ts-module",
    "entrypoint": "implementations/prompts.ts",
    "execution": {
      "kind": "inline-ts",
      "config": {
        "npm_packages": [
          "@more0ai/client@workspace:*"
        ]
      }
    }
  }
}
