{
  "definition": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "schema://llm/chat-output",
    "title": "LLM Chat Completion Output",
    "type": "object",
    "properties": {
      "content": {
        "type": "string",
        "description": "Generated text content"
      },
      "finish_reason": {
        "type": "string",
        "description": "Reason the generation stopped (stop, length, tool_calls, etc.)"
      },
      "model": {
        "type": "string",
        "description": "Model that produced the response"
      },
      "usage": {
        "type": "object",
        "description": "Token usage statistics",
        "properties": {
          "prompt_tokens": { "type": "integer" },
          "completion_tokens": { "type": "integer" },
          "total_tokens": { "type": "integer" }
        }
      },
      "tool_calls": {
        "type": "array",
        "description": "Tool calls requested by the model"
      },
      "message": {
        "type": "object",
        "description": "Full message object from the provider"
      }
    }
  }
}
