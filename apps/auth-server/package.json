{
  "name": "@morezero/auth-server",
  "version": "0.3.1",
  "description": "Express-based OAuth/OIDC Authorization Server with MCP compliance and M2M client management",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/styles.css --minify && tsc",
    "build:css": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/styles.css",
    "build:css:watch": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./public/styles.css --watch",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "start:dev": "tsx src/server.ts",
    "start:watch": "nodemon --exec \"tsx src/server.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "jest --config jest.config.mjs",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "clean": "npx rimraf -I .turbo .vercel dist .next tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@morezero/telemetry": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@types/connect-redis": "^0.0.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@upstash/redis": "^1.35.6",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "desm": "^1.3.1",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.36.4",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.1",
    "jose": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "nanoid": "^5.1.6",
    "pino": "latest",
    "node-fetch": "^3.3.2",
    "oidc-provider": "^9.5.1",
    "openid-client": "^6.8.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "postgres": "^3.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/forms": "^0.5.10",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.17",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.2",
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^3.0.13",
    "@types/passport-local": "^1.0.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^30.0.5",
    "pino-pretty": "latest",
    "nodemon": "^3.0.2",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.1.3"
  }
}
