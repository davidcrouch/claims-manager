# This allows other services to register as OAuth2.1 clients dynamically
DYNAMIC_REGISTRATION_SECRET=a7ecc2a16c2c141be7db656c426875e2a6582f8aad53f0e5bed53f40bfd0b122

# DCR IAT Signing Key - Used for signing Initial Access Tokens in DCR
# Base64-encoded key for cryptographic operations
DCR_IAT_SIGNING_KEY=PuJQOoqZHs0YGiO0hoZsOW9/4e3lXfDq9YkrFb4jqvQ=

# =============================================================================
# REDIS CONFIGURATION (REQUIRED)
# =============================================================================
# Redis is used for session storage, token caching, and rate limiting
# Use shared infra Redis by default (infra/compose.yaml => localhost:3250)
REDIS_PROVIDER="self-hosted"             # self-hosted | upstash
REDIS_HOST="localhost"
REDIS_PORT=3250
REDIS_DB=0
REDIS_TLS=false
# REDIS_PASSWORD=""
#
# If using Upstash instead:
# REDIS_PROVIDER="upstash"
# UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# =============================================================================
BASE_URL=https://auth.example.com

# =============================================================================
# GOOGLE OAUTH CONFIGURATION (OPTIONAL)
# =============================================================================
# Google OAuth credentials for social login integration
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# CORS CONFIGURATION
# =============================================================================
# Allowed origins for Cross-Origin Resource Sharing
# Comma-separated list of allowed origins (protocol + domain + port)
CORS_ORIGINS=http://localhost:3000,http://localhost:3020,https://chat.example.com,https://auth.example.com

# =============================================================================
# TOKEN TTL CONFIGURATION
# =============================================================================
# Token Time-To-Live settings for OIDC tokens
# All values are in seconds
OIDC_ACCESS_TOKEN_TTL=900              # Access token lifetime (15 mins)
OIDC_REFRESH_TOKEN_TTL=604800          # Refresh token lifetime (7 days)
OIDC_ID_TOKEN_TTL=3600                 # ID token lifetime (1 hour)
OIDC_AUTHORIZATION_CODE_TTL=600        # Authorization code lifetime (10 minutes)

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
# Rate limiting settings to prevent abuse
RATE_LIMIT_WINDOW_MS=60                # Time window in seconds (60 = 1 minute)
RATE_LIMIT_MAX_REQUESTS=1000           # Maximum requests per window per IP (10x increase)
RATE_LIMIT_AUTH_MAX_REQUESTS=50        # Maximum auth requests per window per IP
RATE_LIMIT_TOKEN_MAX_REQUESTS=200      # Maximum token requests per window per IP
RATE_LIMIT_OAUTH_MAX_REQUESTS=300      # Maximum OAuth requests per window per IP

# =============================================================================
# MCP CONFIGURATION
# =============================================================================
# MCP (Model Context Protocol) audience URL
# Used for MCP token validation and authorization
AUDIENCE=http://more0.ai

# =============================================================================
# MOREZERO BACKEND INTEGRATION
# =============================================================================
# Node.js API URL for authentication services
# This is the API server that handles auth endpoints
MOREZERO_NODEJS_API_URL=https://morezero-alb-dev-s3.wonderbricks.com:6040
MOREZERO_KOTLIN_API_URL=https://morezero-alb-dev-s3.wonderbricks.com:6070

# More0 API URL for additional service integration
MOREZERO_API_URL=https://api.example.com

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level for the auth server
# Options: error, warn, info, debug, trace
MOREZERO_LOG_LEVEL='info'
MOREZERO_LOG_LEVELS="auth-server:auth-routes=info, auth-server:oidc-provider=info, auth-server:oidc-provider-events=info, auth-server:token-exchange-service=warn, auth-server:backend-token-exchange-service=warn"
MOREZERO_FORMAT_LOG=false

# =============================================================================
# OIDC COOKIE ENCRYPTION (REQUIRED)
# =============================================================================
# Encryption keys for OIDC cookies
# Must be an array of base64-encoded keys (first key is used for encryption)
# Generate with: openssl rand -base64 32
OIDC_COOKIES_KEYS=["53AQq0/OrW0tIbr0Sz+dXr7uU/TGoczLvNZCt3Un9X0=","+UuVG0gy9nGVzB26TksLta94luUzojtW2FybEaVLakM="]

# =============================================================================
# STATIC OIDC CLIENT CONFIGURATION (REQUIRED)
# =============================================================================
# Pre-configured OIDC client for chat-ui application
# This client is automatically registered and available for use
OIDC_CLIENT_ID=morezero-chat-ui                                  # Client identifier
OIDC_CLIENT_SECRET=cs_7f8a9b2c4d5e6f7g8h9i0j1k2l3m4n5o6p7q8r9s0t1u2v3w4x5y6z7a8b9c0d1e2f3g4h  # Client secret
OIDC_CLIENT_CALLBACK_URI=https://chat.example.com/api/auth/oidc/callback  # Primary callback URL for authorization code flow
OIDC_ADDITIONAL_REDIRECT_URIS=https://app.example.com/api/auth/oidc/callback  # Additional redirect URIs (comma-separated) for multiple apps
OIDC_POST_LOGIN_URI=https://chat.example.com/app              # Post-login redirect URL
OIDC_POST_LOGOUT_URI=https://chat.example.com

# =============================================================================
# ENVIRONMENT VARIABLE VALIDATION
# =============================================================================
# The auth server will validate all required environment variables on startup.
# If any required variables are missing or invalid, the server will fail to start
# with a descriptive error message.
#
# REQUIRED VARIABLES:
# - NODE_ENV, PORT, OIDC_ISSUER
# - JWT_SECRET, DYNAMIC_REGISTRATION_SECRET, DCR_IAT_SIGNING_KEY
# - REDIS_PROVIDER + (REDIS_HOST, REDIS_PORT) for self-hosted Redis
#   OR REDIS_PROVIDER=upstash + (UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN)
# - OIDC_COOKIES_KEYS, OIDC_CLIENT_ID, OIDC_CLIENT_SECRET, OIDC_CALLBACK_URI
# - MOREZERO_KOTLIN_API_URL
#
# OPTIONAL VARIABLES:
# - CORS_ORIGINS, RATE_LIMIT_*, GOOGLE_CLIENT_*, AUDIENCE, MOREZERO_LOG_LEVEL
# =============================================================================

